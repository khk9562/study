# 로컬 테스트용 환경변수. 이 파일을 복사해 `.env` 로 만들어 채우세요. (.env 는 git 무시됨)

# Notion
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=8216a0e8-6034-4f7c-8937-d958bcedf06e

# 치환 사전(JSON 한 줄). 로컬 dry-run 테스트용. 실제 운영값은 gh secret 으로 관리 권장.
REDACTION_MAP={"bmtsys":"회사B","Cruiser":"프로젝트S"}

# Telegram 알림
TELEGRAM_BOT_TOKEN=123456:ABCdefGhIJklmNoPQRstuVwxyz
TELEGRAM_CHAT_ID=123456789
